{
  "name": "libraryreach-e2e",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  },
  "scripts": {
    "e2e": "playwright test",
    "e2e:report": "playwright show-report reports/playwright-report",
    "e2e:screenshots": "playwright test -g \"@screenshots\"",
    "test:all": "pytest -q && playwright test && python scripts/update_readme.py",
    "demo:dev": "npm --prefix demo-app run dev",
    "demo:build": "npm --prefix demo-app run build",
    "demo:preview": "npm --prefix demo-app run preview",
    "dev": "npm --prefix demo-app run dev",
    "build": "npm --prefix demo-app run build"
  }
}
